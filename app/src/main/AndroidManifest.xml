<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.snap.tiles">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application
        android:name="com.snap.tiles.QuickTilesApp"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_app_logo"
        android:roundIcon="@mipmap/ic_app_logo_round"
        android:theme="@style/Theme.QuickTiles">

        <activity
            android:name="com.snap.tiles.ui.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.QuickTiles">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.snap.tiles.ui.ShortcutActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.NoDisplay">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 3 Fixed Tiles (always enabled) -->
        <service android:name="com.snap.tiles.tile.UsbDebugTile"
            android:label="@string/tile_usb_debugging"
            android:icon="@drawable/ic_tile_usb_debug"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service android:name="com.snap.tiles.tile.DevModeTile"
            android:label="@string/tile_developer_mode"
            android:icon="@drawable/ic_tile_dev_mode"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service android:name="com.snap.tiles.tile.AccessibilityTile"
            android:label="@string/tile_accessibility"
            android:icon="@drawable/ic_tile_accessibility"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- 5 Custom Tiles (Five Elements) -->
        <service android:name="com.snap.tiles.tile.TileKim"
            android:label="@string/slot_metal"
            android:icon="@drawable/ic_tile_metal"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true" android:enabled="false">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service android:name="com.snap.tiles.tile.TileMoc"
            android:label="@string/slot_wood"
            android:icon="@drawable/ic_tile_wood"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true" android:enabled="false">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service android:name="com.snap.tiles.tile.TileThuy"
            android:label="@string/slot_water"
            android:icon="@drawable/ic_tile_water"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true" android:enabled="false">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service android:name="com.snap.tiles.tile.TileHoa"
            android:label="@string/slot_fire"
            android:icon="@drawable/ic_tile_fire"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true" android:enabled="false">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service android:name="com.snap.tiles.tile.TileTho"
            android:label="@string/slot_earth"
            android:icon="@drawable/ic_tile_earth"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true" android:enabled="false">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Floating overlay tile service -->
        <service
            android:name="com.snap.tiles.float.FloatingTileService"
            android:foregroundServiceType="specialUse"
            android:exported="false">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="floating_tile_overlay" />
        </service>

        <receiver android:name="com.snap.tiles.receiver.BootReceiver" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name="com.snap.tiles.widget.TileWidget"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.snap.tiles.WIDGET_TOGGLE" />
                <action android:name="com.snap.tiles.WIDGET_CONFIGURE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_tile_info" />
        </receiver>

    </application>
</manifest>
